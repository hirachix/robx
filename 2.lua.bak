local function teleportPlayer(x, y, z, locationName)
    local player = game.Players.LocalPlayer;
    if (player and player.Character and player.Character:FindFirstChild("HumanoidRootPart")) then
        player.Character.HumanoidRootPart.CFrame = CFrame.new(x, y + summitDelay, z);
    end
    Rayfield:Notify({
        Title = "Teleported",
        Content = "Berhasil teleport ke " .. locationName,
        Duration = 3,
        Image = "rbxassetid://4483362458"
    });
end

local TeleportInfoSection = TeleportTab:CreateSection("Informasi Teleport");
TeleportTab:CreateParagraph({
    Title = "💡 Cara Menggunakan",
    Content = "- Teleport (Spawnpoint)\nMenu ini akan memindahkanmu langsung ke titik awal (Spawnpoint).\n\n- Teleport (Checkpoint 1 - Puncak)\nMenu ini akan memindahkanmu ke checkpoint sesuai pilihan tombol yang ditekan"
});

local TeleportButtonsSection = TeleportTab:CreateSection("Tombol Teleport");
for _, checkpoint in ipairs(summitCheckpoints) do
    TeleportTab:CreateButton({
        Name = "Teleport ke " .. checkpoint.Name,
        Callback = function()
            teleportPlayer(checkpoint.X, checkpoint.Y, checkpoint.Z, checkpoint.Name);
        end
    });
end

-- =============================================================
--  FILE MANAGEMENT TAB
-- =============================================================
local fileCheckInProgress = false;
local cancelUpdate = { false };
local FileManagementInfoSection = FileManagementTab:CreateSection("Informasi File Management");
FileManagementTab:CreateParagraph({
    Title = "💡 Tentang File Management",
    Content = "Menu ini digunakan untuk mengecek dan mengupdate file yang dibutuhkan oleh script agar fitur dapat berjalan dengan lancar.\n\nJika ada file yang gagal diunduh atau rusak, gunakan tombol 'Mulai Update File' untuk memperbaikinya secara otomatis."
});
local fileStatusLabel = FileManagementTab:CreateLabel("Status: Siap untuk mengecek file...");
task.spawn(function()
    for i, file in ipairs(CheckpointFiles) do
        local success = downloadFile(file);
        fileStatusLabel:Set(((success and "✔ Proses Cek File: ") or "❌ Gagal: ") .. "(" .. i .. "/" .. #CheckpointFiles .. ")");
        task.wait(0.5);
    end
    fileStatusLabel:Set("✔ Semua file aman");
end);
FileManagementTab:CreateToggle({
    Name = "Mulai Update File",
    Callback = function(state)
        if state then
            fileCheckInProgress = true;
            cancelUpdate[1] = false;
            task.spawn(function()
                fileStatusLabel:Set("🔄 Proses update file...");
                for _, file in ipairs(CheckpointFiles) do
                    local filePath = DataFolderName .. "/" .. file;
                    if isfile(filePath) then
                        delfile(filePath);
                    end
                end
                for i, file in ipairs(CheckpointFiles) do
                    if cancelUpdate[1] then break; end
                    Rayfield:Notify({
                        Title = "Mengunduh File",
                        Content = "Sedang mengunduh file... " .. "(" .. i .. "/" .. #CheckpointFiles .. ")",
                        Duration = 2,
                        Image = "rbxassetid://4483362458"
                    });
                    local success, content = pcall(function()
                        return game:HttpGet(dataFilesUrl .. file);
                    end);
                    if (success and content and (#content > 0)) then
                        writefile(DataFolderName .. "/" .. file, content);
                        fileStatusLabel:Set("📥 Proses Update: " .. "(" .. i .. "/" .. #CheckpointFiles .. ")");
                    else
                        Rayfield:Notify({
                            Title = "Error",
                            Content = "❌ Update script gagal",
                            Duration = 3,
                            Image = "rbxassetid://4483362458"
                        });
                        fileStatusLabel:Set("❌ Gagal: " .. "(" .. i .. "/" .. #CheckpointFiles .. ")");
                    end
                    task.wait(0.3);
                end
                if not cancelUpdate[1] then
                    Rayfield:Notify({
                        Title = "Selesai",
                        Content = "Semua file berhasil diupdate.",
                        Duration = 5,
                        Image = "rbxassetid://4483362458"
                    });
                else
                    Rayfield:Notify({
                        Title = "Dibatalkan",
                        Content = "❌ Update canceled",
                        Duration = 3,
                        Image = "rbxassetid://4483362458"
                    });
                end
                for i, file in ipairs(CheckpointFiles) do
                    local success = downloadFile(file);
                    fileStatusLabel:Set(((success and "✔ Cek File: ") or "❌ Failed: ") .. "(" .. i .. "/" .. #CheckpointFiles .. ")");
                    task.wait(0.3);
                end
                fileStatusLabel:Set("✔ Semua file aman");
            end);
        else
            fileCheckInProgress = false;
            cancelUpdate[1] = true;
        end
    end,
    Enabled = false
});

