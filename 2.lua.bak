--  AUTO WALK / MOVEMENT REPLAY SYSTEM
-- =============================================================
local RootFolderName = "Hirako";
local DataFolderName = RootFolderName .. "/json_mt_stecu";

if not isfolder(RootFolderName) then makefolder(RootFolderName); end
if not isfolder(DataFolderName) then makefolder(DataFolderName); end

local dataFilesUrl = "https://raw.githubusercontent.com/rullzsy/rullzsy-script-data/main/json_mt_stecu/";
local CheckpointFiles = {
    "cp_1.json", "cp_2.json", "cp_3.json", "cp_4.json", "cp_5.json", "cp_6.json",
    "cp_7.json", "cp_8.json", "cp_9.json", "cp_10.json", "cp_11.json", "cp_12.json",
    "cp_13.json", "cp_14.json", "cp_15.json", "cp_16.json", "cp_17.json", "cp_18.json",
    "cp_19.json", "cp_20.json", "cp_21.json", "cp_22.json", "cp_23.json", "cp_24.json",
    "cp_25.json", "cp_26.json"
};

-- State variables for movement replay
local isReplaying = false;
local replayConnection = nil;
local isAutoWalkAll = false;
local currentCheckpointIndex = 0;
local isPaused = false;
local wasPaused = false;
local pauseStartTime = 0;
local totalPausedTime = 0;
local lastFrameTime = 0;
local elapsedTime = 0;

-- Helper functions for movement
local function toTable(vector) return { x = vector.X, y = vector.Y, z = vector.Z }; end
local function toVector3(tbl) return Vector3.new(tbl.x, tbl.y, tbl.z); end
local function lerp(a, b, t) return a + ((b - a) * t); end
local function lerpVector3(vA, vB, t) return Vector3.new(lerp(vA.X, vB.X, t), lerp(vA.Y, vB.Y, t), lerp(vA.Z, vB.Z, t)); end
local function lerpAngle(a, b, t)
    local diff = b - a;
    while diff > math.pi do diff = diff - (2 * math.pi); end
    while diff < -math.pi do diff = diff + (2 * math.pi); end
    return a + (diff * t);
end

-- File handling functions
local function downloadFile(fileName)
    local filePath = DataFolderName .. "/" .. fileName;
    if isfile(filePath) then
        return true, filePath;
    end
    local success, content = pcall(function()
        return game:HttpGet(dataFilesUrl .. fileName);
    end);
    if (success and content and (#content > 0)) then
        writefile(filePath, content);
        return true, filePath;
    end
    return false, nil;
end

local function loadJsonFile(fileName)
    local filePath = DataFolderName .. "/" .. fileName;
    if not isfile(filePath) then
        warn("File does not exist:", filePath);
        return nil;
    end
    local success, data = pcall(function()
        local fileContent = readfile(filePath);
        if (not fileContent or (fileContent == "")) then
            error("File is empty or could not be read.");
        end
        return HttpService:JSONDecode(fileContent);
    end);
    if (success and data) then
        return data;
    else
        warn("❌ Load error for", fileName, ":", data);
        return nil;
    end
end

-- Keyframe interpolation
local function findKeyframes(keyframes, time)
    if (#keyframes == 0) then return nil, nil, 0; end
    if (time <= keyframes[1].time) then return 1, 1, 0; end
    if (time >= keyframes[#keyframes].time) then return #keyframes, #keyframes, 0; end

    local low, high = 1, #keyframes;
    while low < (high - 1) do
        local mid = math.floor((low + high) / 2);
        if (keyframes[mid].time <= time) then
            low = mid;
        else
            high = mid;
        end
    end

    local prev, next = low, high;
    local timeDiff = keyframes[next].time - keyframes[prev].time;
    local alpha = ((timeDiff > 0) and math.clamp((time - keyframes[prev].time) / timeDiff, 0, 1)) or 0;
    return prev, next, alpha;
end

-- Movement Replay Control
local function stopReplay()
    isReplaying = false;
    isPaused = false;
    pauseStartTime = 0;
    elapsedTime = 0;
    lastFrameTime = 0;
    if replayConnection then
        replayConnection:Disconnect();
        replayConnection = nil;
    end
end

local function startReplay(keyframes, onComplete)
    if (not keyframes or (#keyframes == 0)) then
        warn("No keyframes provided to replay.");
        if onComplete then onComplete(); end
        return;
    end

    if isReplaying then stopReplay(); end

    isReplaying = true;
    isPaused = false;
    pauseStartTime = 0;
    elapsedTime = 0;
    local startTime = tick();
    lastFrameTime = startTime;
    local wasJumping = false;

    if replayConnection then replayConnection:Disconnect(); replayConnection = nil; end

    local firstKeyframe = keyframes[1];
    if (Character and Character:FindFirstChild("HumanoidRootPart")) then
        local hrp = Character.HumanoidRootPart;
        local startPos = toVector3(firstKeyframe.position);
        local startRot = firstKeyframe.rotation or 0;
        local startCFrame = CFrame.new(startPos) * CFrame.Angles(0, startRot, 0);
        hrp.CFrame = startCFrame;
        hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0);
        hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0);
        if Humanoid then
            Humanoid:Move(toVector3(firstKeyframe.moveDirection or { x = 0, y = 0, z = 0 }), false);
        end
    end

    replayConnection = RunService.Heartbeat:Connect(function(dt)
        if not isReplaying then return; end

        if isPaused then
            if (pauseStartTime == 0) then pauseStartTime = tick(); end
            lastFrameTime = tick();
            return;
        elseif (pauseStartTime > 0) then
            totalPausedTime = totalPausedTime + (tick() - pauseStartTime);
            pauseStartTime = 0;
            lastFrameTime = tick();
        end

        if (not Character or not Character:FindFirstChild("HumanoidRootPart")) then return; end
        if (not Humanoid or (Humanoid.Parent ~= Character)) then
            Humanoid = Character:FindFirstChild("Humanoid");
        end

        local currentTime = tick();
        local frameDt = currentTime - lastFrameTime;
        lastFrameTime = currentTime;
        frameDt = math.min(frameDt, 0.1);
        elapsedTime = elapsedTime + frameDt;

        local totalTime = keyframes[#keyframes].time;
        if (elapsedTime > totalTime) then
            local lastKeyframe = keyframes[#keyframes];
            if (Character and Character:FindFirstChild("HumanoidRootPart")) then
                local hrp = Character.HumanoidRootPart;
                local endPos = toVector3(lastKeyframe.position);
                local endRot = lastKeyframe.rotation or 0;
                local endCFrame = CFrame.new(endPos) * CFrame.Angles(0, endRot, 0);
                hrp.CFrame = endCFrame;
                if Humanoid then
                    Humanoid:Move(toVector3(lastKeyframe.moveDirection or { x = 0, y = 0, z = 0 }), false);
                end
            end
            stopReplay();
            if onComplete then onComplete(); end
            return;
        end

        local prevIdx, nextIdx, alpha = findKeyframes(keyframes, elapsedTime);
        local prevKey, nextKey = keyframes[prevIdx], keyframes[nextIdx];
        if (not prevKey or not nextKey) then return; end

        -- Interpolate values
        local pos = lerpVector3(toVector3(prevKey.position), toVector3(nextKey.position), alpha);
        local vel = lerpVector3(toVector3(prevKey.velocity or { x = 0, y = 0, z = 0 }), toVector3(nextKey.velocity or { x = 0, y = 0, z = 0 }), alpha);
        local moveDir = lerpVector3(toVector3(prevKey.moveDirection or { x = 0, y = 0, z = 0 }), toVector3(nextKey.moveDirection or { x = 0, y = 0, z = 0 }), alpha);
        local rot = lerpAngle(prevKey.rotation or 0, nextKey.rotation or 0, alpha);

        -- Apply to character
        local hrp = Character.HumanoidRootPart;
        local targetCFrame = CFrame.new(pos) * CFrame.Angles(0, rot, 0);
        local lerpAlpha = math.clamp(1 - math.exp(-10 * frameDt), 0, 1);
        hrp.CFrame = hrp.CFrame:Lerp(targetCFrame, lerpAlpha);
        pcall(function() hrp.AssemblyLinearVelocity = vel; end);
        if Humanoid then Humanoid:Move(moveDir, false); end

        -- Handle jumping
        local isJumping = prevKey.jumping or false;
        if nextKey.jumping then isJumping = true; end
        if (isJumping and not wasJumping) then
            if Humanoid then Humanoid:ChangeState(Enum.HumanoidStateType.Jumping); end
        end
        wasJumping = isJumping;
    end);
end

-- =============================================================
--  AUTO WALK TAB
-- =============================================================
local function startAutoWalkAll()
    currentCheckpointIndex = 0;
    local function playNextCheckpoint()
        if not isAutoWalkAll then return; end

        currentCheckpointIndex = currentCheckpointIndex + 1;
        if (currentCheckpointIndex > #CheckpointFiles) then
            isAutoWalkAll = false;
            Rayfield:Notify({
                Title = "Auto Walk Selesai",
                Content = "Kamu berhasil menjalankan semua checkpoint Auto Walk secara otomatis!",
                Duration = 5,
                Image = "rbxassetid://4483362458"
            });
            return;
        end

        local fileName = CheckpointFiles[currentCheckpointIndex];
        local success, _ = downloadFile(fileName);
        if not success then
            Rayfield:Notify({
                Title = "Error",
                Content = "Gagal mengunduh file checkpoint. Silakan coba lagi.",
                Duration = 5,
                Image = "rbxassetid://4483362458"
            });
            isAutoWalkAll = false;
            return;
        end

        local keyframes = loadJsonFile(fileName);
        if (keyframes and (#keyframes > 0)) then
            Rayfield:Notify({
                Title = "Auto Walk (Otomatis)",
                Content = "Menjalankan Auto Walk untuk Checkpoint " .. tostring(currentCheckpointIndex) .. "/" .. tostring(#CheckpointFiles),
                Duration = 2,
                Image = "rbxassetid://4483362458"
            });
            task.wait(0.5);
            startReplay(keyframes, playNextCheckpoint);
        else
            Rayfield:Notify({
                Title = "Error",
                Content = "Gagal memuat data untuk checkpoint: " .. fileName,
                Duration = 5,
                Image = "rbxassetid://4483362458"
            });
            isAutoWalkAll = false;
        end
    end
    playNextCheckpoint();
end

local function startManualAutoWalk(fileName)
    isAutoWalkAll = false;
    stopReplay();
    local success = downloadFile(fileName);
    if not success then
        Rayfield:Notify({
            Title = "Error",
            Content = "Gagal mengunduh file checkpoint. Silakan coba lagi.",
            Duration = 4,
            Image = "rbxassetid://4483362458"
        });
        return;
    end

    local keyframes = loadJsonFile(fileName);
    if (not keyframes or (#keyframes == 0)) then
        Rayfield:Notify({
            Title = "Error",
            Content = "Gagal memuat data untuk checkpoint yang dipilih.",
            Duration = 4,
            Image = "rbxassetid://4483362458"
        });
        return;
    end

    Rayfield:Notify({
        Title = "Auto Walk (Manual)",
        Content = "Memulai Auto Walk dari Checkpoint yang dipilih. Harap tunggu...",
        Duration = 3,
        Image = "rbxassetid://4483362458"
    });
    startReplay(keyframes, function()
        Rayfield:Notify({
            Title = "Auto Walk Selesai",
            Content = "Auto Walk untuk checkpoint yang dipilih telah selesai.",
            Duration = 2,
            Image = "rbxassetid://4483362458"
        });
    end);
end

