-- API Configuration
local ApiConfig = {
    base_url = "https://api.rullzsy.com/api/v1/tower-of-hell",
    get_user_endpoint = "/user/get"
};

-- HTTP Request Wrapper Function
local function sendApiRequest(url, method, body, headers)
    method = method or "GET";
    local requestData = {
        Url = url,
        Method = method
    };
    if headers then
        requestData.Headers = headers;
    end
    if (body and (method == "POST")) then
        requestData.Body = body;
    end

    local success, response = pcall(function()
        return HttpService:RequestAsync(requestData);
    end);

    if (success and response) then
        if (response.Success and (response.StatusCode == 200)) then
            return true, response.Body;
        else
            return false, "HTTP " .. (response.StatusCode or "N/A") .. ": " .. (response.StatusMessage or "Unknown Error");
        end
    end

    if (method == "GET") then
        local getSuccess, getResponse = pcall(function()
            return HttpService:GetAsync(url, false);
        end);
        if (getSuccess and getResponse) then
            return true, getResponse;
        end
        local httpGetSuccess, httpGetResponse = pcall(function()
            return game:HttpGet(url);
        end);
        if (httpGetSuccess and httpGetResponse) then
            return true, httpGetResponse;
        end
    end
    return false, tostring(response);
end

