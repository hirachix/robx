local function setWalkspeed(enabled)
    local player = game.Players.LocalPlayer;
    if not player.Character then return; end
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid");
    if humanoid then
        if enabled then
            humanoid.WalkSpeed = 16;
            humanoid.JumpPower = 50;
        else
            humanoid.WalkSpeed = 0;
            humanoid.JumpPower = 0;
        end
    end
end

local function getHumanoid()
    local player = game.Players.LocalPlayer;
    if player.Character then
        return player.Character:FindFirstChildOfClass("Humanoid");
    end
    return nil;
end

local function enableGodMode()
    local humanoid = getHumanoid();
    if not humanoid then return; end
    humanoid.Health = humanoid.MaxHealth;
    godModeConnection = humanoid.HealthChanged:Connect(function()
        if isAutoSummitActive then
            humanoid.Health = humanoid.MaxHealth;
        end
    end);
    antiFallConnection = humanoid.StateChanged:Connect(function(oldState, newState)
        if (isAutoSummitActive and (newState == Enum.HumanoidStateType.Freefall)) then
            humanoid:ChangeState(Enum.HumanoidStateType.PlatformStanding);
        end
    end);
end

local function disableGodMode()
    if godModeConnection then
        godModeConnection:Disconnect();
        godModeConnection = nil;
    end
    if antiFallConnection then
        antiFallConnection:Disconnect();
        antiFallConnection = nil;
    end
end

local function summitTeleport(checkpoint, delay)
    for i = delay, 1, -1 do
        if not isAutoSummitActive then return false; end
        Rayfield:Notify({
            Title = "Teleporting",
            Content = "Teleporting to " .. checkpoint.Name,
            Subtext = "Teleporting in " .. i,
            Duration = 1,
            Image = "rbxassetid://4483362458"
        });
        task.wait(1);
    end

    local player = game.Players.LocalPlayer;
    if (player and player.Character and player.Character:FindFirstChild("HumanoidRootPart")) then
        player.Character.HumanoidRootPart.CFrame = CFrame.new(checkpoint.X, checkpoint.Y + summitDelay, checkpoint.Z);
    end

    Rayfield:Notify({
        Title = "Teleported",
        Content = "Successfully teleported to " .. checkpoint.Name,
        Duration = 2,
        Image = "rbxassetid://4483362458"
    });
    return true;
end

-- UI for Auto Summit Tab
local SummitInfoSection = AutoSummitTab:CreateSection("Informasi Auto Summit");
AutoSummitTab:CreateParagraph({
    Title = "💡 Cara Menggunakan",
    Content = "- Auto Summit (Automatic)\nPada menu ini kamu bisa menjalankan Auto Summit secara otomatis, dari awal hingga akhir.\nKamu juga dapat mengatur kecepatan otomatis pada opsi Setting Speed.\n\n- Auto Summit (Manual)\nPada menu ini kamu bisa memilih checkpoint tertentu untuk memulai Auto Summit secara manual.\nSetelah memilih checkpoint, aktifkan Mulai Auto Summit (Manual) untuk berjalan dari titik tersebut.\nKamu juga dapat mengatur kecepatan manual pada opsi Setting Speed.\n\n⚠️ Catatan:\nGunakan hanya salah satu mode (Automatic atau Manual). Menyalakan keduanya sekaligus dapat menyebabkan bug."
});

local AutoSummitAutomaticSection = AutoSummitTab:CreateSection("Auto Summit (Automatic)");
AutoSummitTab:CreateToggle({
    Name = "Mulai Auto Summit (Otomatis)",
    Callback = function(state)
        isAutoSummitActive = state;
        if isAutoSummitActive then
            task.spawn(function()
                setWalkspeed(false);
                enableGodMode();
                while isAutoSummitActive do
                    for _, checkpoint in ipairs(summitCheckpoints) do
                        if not summitTeleport(checkpoint, manualSummitSpeed) then
                            break;
                        end
                    end
                    Rayfield:Notify({
                        Title = "Auto Summit Selesai",
                        Content = "Kamu berhasil menyelesaikan Auto Summit.",
                        Duration = 3,
                        Image = "rbxassetid://4483362458"
                    });
                    task.wait(1);
                end
                setWalkspeed(true);
                disableGodMode();
            end);
        else
            setWalkspeed(true);
            disableGodMode();
        end
    end,
    Enabled = false,
    Flag = "AutoSummitAutomatic"
});
AutoSummitTab:CreateSlider({
    Name = "Setting Speed (Otomatis)",
    Range = { 1, 10 },
    Increment = 1,
    Suffix = " Detik",
    CurrentValue = 3,
    Flag = "AutoSummitSpeed",
    Callback = function(value)
        manualSummitSpeed = value;
    end
});

local AutoSummitManualSection = AutoSummitTab:CreateSection("Auto Summit (Manual)");
local isManualSummitActive = false;
local manualStartCheckpointIndex = 1;
local manualSummitSpeedManual = 3;
local manualStartCheckpointName = summitCheckpoints[1].Name;

AutoSummitTab:CreateDropdown({
    Name = "Pilih Checkpoint Awal",
    Options = (function()
        local names = {};
        for _, cp in ipairs(summitCheckpoints) do table.insert(names, cp.Name); end
        return names;
    end)(),
    CurrentOption = manualStartCheckpointName,
    Flag = "ManualStartCheckpoint",
    Callback = function(option)
        manualStartCheckpointName = option;
        for i, cp in ipairs(summitCheckpoints) do
            if (cp.Name == manualStartCheckpointName) then
                manualStartCheckpointIndex = i;
                break;
            end
        end
        Rayfield:Notify({
            Title = "Checkpoint Dipilih",
            Content = "Checkpoint awal diatur ke: " .. manualStartCheckpointName,
            Duration = 3,
            Image = "rbxassetid://4483362458"
        });
    end
});

AutoSummitTab:CreateToggle({
    Name = "Mulai Auto Summit (Manual)",
    Callback = function(state)
        isManualSummitActive = state;
        if isManualSummitActive then
            task.spawn(function()
                setWalkspeed(false);
                enableGodMode();
                while isManualSummitActive do
                    for i = manualStartCheckpointIndex, #summitCheckpoints do
                        local checkpoint = summitCheckpoints[i];
                        if not summitTeleport(checkpoint, manualSummitSpeedManual) then
                            break;
                        end
                    end
                    manualStartCheckpointIndex = 1;
                    Rayfield:Notify({
                        Title = "Selesai",
                        Content = "Auto Summit (Manual) telah selesai. Jika ingin mengulang, matikan dan nyalakan kembali toggle ini.",
                        Duration = 2,
                        Image = "rbxassetid://4483362458"
                    });
                end
                setWalkspeed(true);
                disableGodMode();
            end);
        else
            setWalkspeed(true);
            disableGodMode();
            Rayfield:Notify({
                Title = "Dibatalkan",
                Content = "Auto Summit (Manual) telah dibatalkan.",
                Duration = 1,
                Image = "rbxassetid://4483362458"
            });
        end
    end,
    Enabled = false,
    Flag = "AutoSummitManual"
});
AutoSummitTab:CreateSlider({
    Name = "Setting Speed (Manual)",
    Range = { 1, 10 },
    Increment = 1,
    Suffix = " Detik",
    CurrentValue = 3,
    Flag = "ManualSummitSpeed",
    Callback = function(value)
        manualSummitSpeedManual = value;
    end
});

