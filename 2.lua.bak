    Enabled = false
});

local AutoWalkManualSection = AutoWalkTab:CreateSection("Auto Walk (Manual)");

-- Create a toggle for each checkpoint file
local checkpointToggles = {};
for i, fileName in ipairs(CheckpointFiles) do
    local checkpointName = "Checkpoint " .. tostring(i) .. " (Tower " .. tostring(i) .. ")";
    checkpointToggles[i] = AutoWalkTab:CreateToggle({
        Name = checkpointName,
        Callback = function(state)
            if state then
                -- Disable all other toggles
                for j, toggle in ipairs(checkpointToggles) do
                    if i ~= j then
                        toggle:Set(false);
                    end
                end
                startManualAutoWalk(fileName);
            else
                stopReplay();
            end
        end,
        Enabled = false
    });
end


